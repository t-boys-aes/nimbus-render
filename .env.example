# Gemini API Key (Required for script generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Pexels API Key (Optional, pipeline falls back to local visual placeholders if empty)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Key (Optional, secondary stock video source fallback)
PIXABAY_API_KEY=your_pixabay_api_key_here

# YouTube OAuth2 Credentials (Required for headless youtube upload)
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here

# Google Drive & Sheets Configuration (OAuth2 credentials are shared)
# If left empty, the pipeline will auto-create a folder/spreadsheet and print the ID.
GDRIVE_FOLDER_ID=your_gdrive_folder_id_here
GSHEET_SPREADSHEET_ID=your_gsheet_spreadsheet_id_here

# Telegram Bot Configuration (For run reports and error logs)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
